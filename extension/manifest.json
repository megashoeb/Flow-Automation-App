{
  "manifest_version": 3,
  "name": "G-Labs Studio Helper",
  "version": "1.1.1",
  "description": "Connects G-Labs Automation Studio to Chrome for fast, reliable image generation",
  "permissions": [
    "tabs",
    "scripting",
    "cookies",
    "webRequest",
    "browsingData",
    "storage"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "https://storage.googleapis.com/*",
    "http://127.0.0.1:18924/*",
    "https://www.google.com/*",
    "https://www.youtube.com/*",
    "https://mail.google.com/*",
    "https://drive.google.com/*",
    "https://news.google.com/*",
    "https://photos.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
